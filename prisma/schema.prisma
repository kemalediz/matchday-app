generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PLAYER
}

enum Position {
  GK
  DEF
  MID
  FWD
}

enum MatchFormat {
  FIVE_A_SIDE
  SEVEN_A_SIDE
}

enum MatchStatus {
  UPCOMING
  TEAMS_GENERATED
  TEAMS_PUBLISHED
  COMPLETED
}

enum AttendanceStatus {
  CONFIRMED
  BENCH
  DROPPED
}

enum Team {
  RED
  YELLOW
}

// ─── NextAuth Adapter Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(PLAYER)
  positions     Position[]
  seedRating    Float?
  isActive      Boolean   @default(true)
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  attendances       Attendance[]
  ratingsGiven      Rating[]         @relation("RatingsGiven")
  ratingsReceived   Rating[]         @relation("RatingsReceived")
  momVotesGiven     MoMVote[]        @relation("MoMVotesGiven")
  momVotesReceived  MoMVote[]        @relation("MoMVotesReceived")
  teamAssignments   TeamAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id                String      @id @default(cuid())
  name              String
  dayOfWeek         Int         // 0=Sun..6=Sat
  time              String      // "21:30"
  venue             String
  format            MatchFormat @default(SEVEN_A_SIDE)
  isActive          Boolean     @default(true)
  deadlineHours     Int         @default(5)
  matchDurationMins Int         @default(60)
  ratingWindowHours Int         @default(48)

  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id                 String      @id @default(cuid())
  activityId         String
  activity           Activity    @relation(fields: [activityId], references: [id])
  date               DateTime
  format             MatchFormat
  maxPlayers         Int
  status             MatchStatus @default(UPCOMING)
  attendanceDeadline DateTime
  redScore           Int?
  yellowScore        Int?

  attendances     Attendance[]
  teamAssignments TeamAssignment[]
  ratings         Rating[]
  momVotes        MoMVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

model Attendance {
  id          String           @id @default(cuid())
  matchId     String
  match       Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      AttendanceStatus @default(CONFIRMED)
  position    Int              @default(0)
  respondedAt DateTime         @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId, status])
}

model TeamAssignment {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  team    Team

  @@unique([matchId, userId])
}

model Rating {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterId  String
  rater    User   @relation("RatingsGiven", fields: [raterId], references: [id])
  playerId String
  player   User   @relation("RatingsReceived", fields: [playerId], references: [id])
  score    Int    // 1-10

  createdAt DateTime @default(now())

  @@unique([matchId, raterId, playerId])
}

model MoMVote {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId  String
  voter    User   @relation("MoMVotesGiven", fields: [voterId], references: [id])
  playerId String
  player   User   @relation("MoMVotesReceived", fields: [playerId], references: [id])

  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
}
