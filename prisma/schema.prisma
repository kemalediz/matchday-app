generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  UPCOMING
  TEAMS_GENERATED
  TEAMS_PUBLISHED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  CONFIRMED
  BENCH
  DROPPED
}

enum Team {
  RED
  YELLOW
}

enum MemberRole {
  OWNER
  ADMIN
  PLAYER
}

// ─── NextAuth Adapter Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phoneNumber   String?   @unique
  seedRating    Float?
  matchRating   Int       @default(1000) // Elo-style; updated after each completed match with a score
  isSuperadmin  Boolean   @default(false) // platform-level operator; see all orgs
  isActive      Boolean   @default(true)
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  attendances       Attendance[]
  ratingsGiven      Rating[]         @relation("RatingsGiven")
  ratingsReceived   Rating[]         @relation("RatingsReceived")
  momVotesGiven     MoMVote[]        @relation("MoMVotesGiven")
  momVotesReceived  MoMVote[]        @relation("MoMVotesReceived")
  teamAssignments   TeamAssignment[]
  activityPositions PlayerActivityPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organisation {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  logo               String?
  inviteCode         String   @unique @default(cuid())
  whatsappGroupId    String?
  whatsappBotEnabled Boolean  @default(false)

  memberships Membership[]
  activities  Activity[]
  sports      Sport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sport {
  id                  String   @id @default(cuid())
  orgId               String
  org                 Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                String               // "Football 7-a-side"
  preset              String?              // "football-7aside" | "basketball-5v5" | null for custom
  playersPerTeam      Int
  positions           String[]             // ["GK","DEF","MID","FWD"]
  teamLabels          String[]             // ["Red","Yellow"]
  mvpLabel            String   @default("Man of the Match")
  balancingStrategy   String   @default("position-aware") // "position-aware" | "rating-only"
  positionComposition Json?                // { GK: 1, DEF: 2, MID: 2, FWD: 2 } — per-team target

  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Membership {
  id     String     @id @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId  String
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role   MemberRole @default(PLAYER)

  /// Non-null when the user has been detected as leaving the org's
  /// WhatsApp group (bot `group_leave` event) or been manually removed
  /// by an admin. We keep the membership row for history (so past
  /// attendances/ratings stay attributable) — just exclude "left" rows
  /// from roster queries. A `group_join` later will null this back out.
  leftAt DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([leftAt])
}

model Activity {
  id                String       @id @default(cuid())
  orgId             String
  org               Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sportId           String
  sport             Sport        @relation(fields: [sportId], references: [id])
  name              String
  dayOfWeek         Int          // 0=Sun..6=Sat
  time              String       // "21:30"
  venue             String
  isActive          Boolean      @default(true)
  deadlineHours     Int          @default(5)
  matchDurationMins Int          @default(60)
  ratingWindowHours Int          @default(120) // 5 days — aligns with MoM announcement & magic-link TTL

  matches           Match[]
  playerPositions   PlayerActivityPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([sportId])
}

model PlayerActivityPosition {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  positions  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, activityId])
  @@index([activityId])
}

model Match {
  id                 String      @id @default(cuid())
  activityId         String
  activity           Activity    @relation(fields: [activityId], references: [id])
  date               DateTime
  maxPlayers         Int
  status             MatchStatus @default(UPCOMING)
  attendanceDeadline DateTime
  redScore           Int?
  yellowScore        Int?
  /// When false, the bot skips match-end postings (payment poll, rating-link DMs,
  /// MoM announcement, rating-reminder DMs) for this specific match. Useful for
  /// the first match after launch while the rating UI is still maturing.
  postMatchEndFlow   Boolean     @default(true)

  attendances            Attendance[]
  teamAssignments        TeamAssignment[]
  ratings                Rating[]
  momVotes               MoMVote[]
  sentNotifications      SentNotification[]
  benchConfirmations     PendingBenchConfirmation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

/**
 * Every WhatsApp-bot message the scheduler asks the bot to send is logged
 * here with a stable key so it doesn't fire twice. Keys look like
 * "<matchId>:<kind>" (group-wide events) or "<matchId>:<kind>:<userId>"
 * (per-user DMs / reminders).
 */
model SentNotification {
  id         String   @id @default(cuid())
  key        String   @unique
  kind       String                    // e.g. "announce-match", "daily-in-list", "match-teams", ...
  matchId    String?
  match      Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  targetUser String?                   // userId when it's a per-user DM
  waMessageId String?                  // WhatsApp message id for reaction tracking
  createdAt  DateTime @default(now())

  @@index([matchId])
  @@index([kind])
}

/**
 * Ad-hoc queue for bot work the scheduler should dispatch on its next
 * tick. Used for one-off admin actions (e.g. "send a test DM to Kemal")
 * that don't map onto the regular match-lifecycle triggers. Scheduler
 * picks up rows with `sentAt == null`, emits matching instructions, and
 * marks `sentAt` on ACK so they don't repeat.
 */
model BotJob {
  id       String   @id @default(cuid())
  orgId    String
  kind     String                   // "dm" | "group"
  phone    String?                  // for DM jobs, E.164 without the + prefix
  text     String   @db.Text
  sentAt   DateTime?
  createdAt DateTime @default(now())

  @@index([orgId, sentAt])
}

/**
 * When someone drops from a confirmed slot, the bot DMs the first bench
 * player and asks them to 👍 (confirm) or 👎 (pass) within 2h. One row
 * per (match, user) attempt. Resolved when a reaction arrives OR when
 * `expiresAt` passes — at which point the server flags this user as
 * dropped and the scheduler posts a new prompt for the next bencher.
 */
model PendingBenchConfirmation {
  id          String    @id @default(cuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  waMessageId String?                // the bot's prompt message id; filled in by /ack
  expiresAt   DateTime
  resolvedAt  DateTime?
  outcome     String?                // "confirmed" | "declined" | "expired"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([resolvedAt])
}

model Attendance {
  id          String           @id @default(cuid())
  matchId     String
  match       Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      AttendanceStatus @default(CONFIRMED)
  position    Int              @default(0)
  respondedAt DateTime         @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId, status])
}

model TeamAssignment {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  team    Team

  @@unique([matchId, userId])
}

model Rating {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterId  String
  rater    User   @relation("RatingsGiven", fields: [raterId], references: [id])
  playerId String
  player   User   @relation("RatingsReceived", fields: [playerId], references: [id])
  score    Int    // 1-10

  createdAt DateTime @default(now())

  @@unique([matchId, raterId, playerId])
}

model MoMVote {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId  String
  voter    User   @relation("MoMVotesGiven", fields: [voterId], references: [id])
  playerId String
  player   User   @relation("MoMVotesReceived", fields: [playerId], references: [id])

  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
}

/**
 * Smart-analysis dedupe key: every WhatsApp group message the bot
 * processes gets recorded here by its `waMessageId`. The inline path
 * (fast-path + LLM), periodic catch-up scan, and startup backfill all
 * check this table first so no message is processed twice. The
 * `intent` / `action` columns record what the bot decided, useful for
 * auditing and prompt-tuning.
 *
 * handledBy:
 *   - "fast-path": regex matched (IN/OUT/score); acted inline
 *   - "llm":       sent to Claude for classification; action executed
 *   - "ignored":   skipped on purpose (bot's own msg, non-c.us author, empty body)
 *   - "error":     analyzer call failed; don't re-try this exact message
 */
model AnalyzedMessage {
  id           String   @id @default(cuid())
  waMessageId  String   @unique
  orgId        String
  groupId      String
  authorPhone  String?
  authorUserId String?
  body         String?  @db.Text
  handledBy    String
  intent       String?
  action       String?
  confidence   Float?
  reasoning    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([groupId, createdAt])
}
