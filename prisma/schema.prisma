generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  UPCOMING
  TEAMS_GENERATED
  TEAMS_PUBLISHED
  COMPLETED
}

enum AttendanceStatus {
  CONFIRMED
  BENCH
  DROPPED
}

enum Team {
  RED
  YELLOW
}

enum MemberRole {
  OWNER
  ADMIN
  PLAYER
}

// ─── NextAuth Adapter Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phoneNumber   String?   @unique
  seedRating    Float?
  isActive      Boolean   @default(true)
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  attendances       Attendance[]
  ratingsGiven      Rating[]         @relation("RatingsGiven")
  ratingsReceived   Rating[]         @relation("RatingsReceived")
  momVotesGiven     MoMVote[]        @relation("MoMVotesGiven")
  momVotesReceived  MoMVote[]        @relation("MoMVotesReceived")
  teamAssignments   TeamAssignment[]
  activityPositions PlayerActivityPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organisation {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  logo               String?
  inviteCode         String   @unique @default(cuid())
  whatsappGroupId    String?
  whatsappBotEnabled Boolean  @default(false)

  memberships Membership[]
  activities  Activity[]
  sports      Sport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sport {
  id                  String   @id @default(cuid())
  orgId               String
  org                 Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                String               // "Football 7-a-side"
  preset              String?              // "football-7aside" | "basketball-5v5" | null for custom
  playersPerTeam      Int
  positions           String[]             // ["GK","DEF","MID","FWD"]
  teamLabels          String[]             // ["Red","Yellow"]
  mvpLabel            String   @default("Man of the Match")
  balancingStrategy   String   @default("position-aware") // "position-aware" | "rating-only"
  positionComposition Json?                // { GK: 1, DEF: 2, MID: 2, FWD: 2 } — per-team target

  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Membership {
  id     String     @id @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId  String
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role   MemberRole @default(PLAYER)

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model Activity {
  id                String       @id @default(cuid())
  orgId             String
  org               Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sportId           String
  sport             Sport        @relation(fields: [sportId], references: [id])
  name              String
  dayOfWeek         Int          // 0=Sun..6=Sat
  time              String       // "21:30"
  venue             String
  isActive          Boolean      @default(true)
  deadlineHours     Int          @default(5)
  matchDurationMins Int          @default(60)
  ratingWindowHours Int          @default(48)

  matches           Match[]
  playerPositions   PlayerActivityPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([sportId])
}

model PlayerActivityPosition {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  positions  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, activityId])
  @@index([activityId])
}

model Match {
  id                 String      @id @default(cuid())
  activityId         String
  activity           Activity    @relation(fields: [activityId], references: [id])
  date               DateTime
  maxPlayers         Int
  status             MatchStatus @default(UPCOMING)
  attendanceDeadline DateTime
  redScore           Int?
  yellowScore        Int?

  attendances     Attendance[]
  teamAssignments TeamAssignment[]
  ratings         Rating[]
  momVotes        MoMVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

model Attendance {
  id          String           @id @default(cuid())
  matchId     String
  match       Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      AttendanceStatus @default(CONFIRMED)
  position    Int              @default(0)
  respondedAt DateTime         @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId, status])
}

model TeamAssignment {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  team    Team

  @@unique([matchId, userId])
}

model Rating {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterId  String
  rater    User   @relation("RatingsGiven", fields: [raterId], references: [id])
  playerId String
  player   User   @relation("RatingsReceived", fields: [playerId], references: [id])
  score    Int    // 1-10

  createdAt DateTime @default(now())

  @@unique([matchId, raterId, playerId])
}

model MoMVote {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId  String
  voter    User   @relation("MoMVotesGiven", fields: [voterId], references: [id])
  playerId String
  player   User   @relation("MoMVotesReceived", fields: [playerId], references: [id])

  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
}
